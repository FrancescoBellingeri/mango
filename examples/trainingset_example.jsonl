{"type": "text", "text": "Database: mango_ecommerce. Collections: customers, orders, products, reviews, suppliers, warehouses, inventory, events, shipments, categories."}
{"type": "text", "text": "customers fields: first_name, last_name, email, country, tier (bronze/silver/gold/platinum), marketing_opt_in (bool), created_at (datetime)."}
{"type": "text", "text": "orders fields: status (pending/confirmed/processing/shipped/delivered/cancelled/returned), total (float), payment_method (credit_card/debit_card/paypal/bank_transfer/crypto), items (array), shipping_address.country, created_at (datetime)."}
{"type": "text", "text": "orders.items array fields: product_id, product_name, qty, final_price, discount_pct, category_id."}
{"type": "text", "text": "products fields: sku, name, brand, price, is_active (bool), category_path (array), rating_count, supplier_id."}
{"type": "text", "text": "reviews fields: rating (1-5 int), is_verified (bool), created_at (datetime)."}
{"type": "text", "text": "inventory fields: warehouse_id, product_id, quantity, below_threshold (bool)."}
{"type": "text", "text": "events fields: type (view/search/cart_add/cart_remove/purchase/wishlist), timestamp (datetime)."}
{"type": "text", "text": "shipments fields: carrier (DHL/FedEx/UPS/BRT/Correos/etc), status, timeline (array with status+timestamp+location)."}
